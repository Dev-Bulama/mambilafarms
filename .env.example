APP_NAME="Mambilla Legacy Farms"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://mambillalegacyfarms.ng

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# ── Database (MySQL) ──────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password

# ── Session / Cache (file-based — safest on shared hosting) ──────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
CACHE_STORE=file
QUEUE_CONNECTION=sync

# ── Mail fallback (admin configures SMTP via /admin/settings) ─────
# These values are overridden at runtime by settings stored in the DB.
# Set them here as a fallback in case the DB is unreachable.
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@mambillalegacyfarms.ng"
MAIL_FROM_NAME="Mambilla Legacy Farms"

FILESYSTEM_DISK=local
